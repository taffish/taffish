# TAFFISH source repository ignore rules.
# Source, docs, installers, completions, vim files, and ASDF/load files are
# tracked by default. Generated local build/cache artifacts are ignored.

# OS/editor noise
.DS_Store
Thumbs.db
*~
*.bak
*.orig
*.tmp
*.swp
*.swo
#*#

# Logs and local scratch files
*.log
*.out
*.err
.cache/
tmp/
temp/
.local/

# Common Lisp / ASDF build outputs
*.fasl
*.ufasl
*.dfsl
*.lx32fsl
*.lx64fsl
*.wx32fsl
*.wx64fsl
*.abcl
*.fas
*.lib
*.x86f
*.sparcf
*.axpf
*.dxf
*.ppcf
*.sse2f

# Build/package scratch directories. The release payload under target/ is kept
# intentionally because the raw installers download versioned binaries from git
# tags for GitHub/Gitee compatibility.
build/
dist/
release/

# Keep only public release payload files in target/.
target/*
!target/taf-*
!target/taffish-*
!target/SHA256SUMS
!target/SHA256SUMS.asc
!target/TAFFISH-RELEASE-KEY.asc

# taf-app publish drafts should not be committed when this repository is used as
# a working TAFFISH project.
release.md
