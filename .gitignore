# Binary distribution repository for TAFFISH.
# Ignore everything by default, then whitelist distribution artifacts.
*

# Root metadata
!.gitignore
!README.md
!README-CN.md
!LICENSE

# Local/internal developer documentation is intentionally kept out of the
# binary distribution repository.
docs/

# Installer (single-file entry)
!install/
install/*
!install/install-taffish.sh
!install/install-taffish.gitee.sh
!install/README.md

# Release payload
!target/
target/*
!target/taf-*
!target/taffish-*

# Optional checksum manifests
!checksums/
!checksums/*

# Shell completion and vim syntax files
!completion/
!completion/**/*
!vim-highlight/
!vim-highlight/**/*

# Optional GitHub workflow files
!.github/
!.github/workflows/
!.github/workflows/*
