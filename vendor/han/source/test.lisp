(in-package :han.test)

;;;; ============================================================
;;;; han.source tests
;;;; ============================================================

(deftest test-han-source-help-and-version ()
  (let ((help-string (han.source:help nil)))
    (check-true (stringp help-string))
    (check-true (search "han.source" help-string))
    (check-true (search "source-read-while" help-string)))
  (check-equal "0.1.0" (han.source:version nil)))

(unless (fboundp 'signal-error-p)
  (defun signal-error-p (thunk)
    (handler-case
        (progn
          (funcall thunk)
          nil)
      (error () t))))

(deftest test-make-char-source ()
  (let ((src (han.source:make-char-source "abc")))
    (check-equal (han.source:char-source-string src) "abc")
    (check-equal (han.source:char-source-length src) 3)
    (multiple-value-bind (index line column)
        (han.source:source-location src)
      (check-equal index 0)
      (check-equal line 1)
      (check-equal column 1))))

(deftest test-source-eof-p ()
  (let ((src (han.source:make-char-source "")))
    (check-equal (han.source:source-eof-p src) t))
  (let ((src (han.source:make-char-source "a")))
    (check-equal (han.source:source-eof-p src) nil)
    (han.source:source-next-char src)
    (check-equal (han.source:source-eof-p src) t)))

(deftest test-source-peek-and-next-char ()
  (let ((src (han.source:make-char-source "abc")))
    (check-equal (han.source:source-peek-char src) #\a)
    ;; peek 不推进
    (multiple-value-bind (index line column)
        (han.source:source-location src)
      (check-equal index 0)
      (check-equal line 1)
      (check-equal column 1))
    ;; next 才推进
    (check-equal (han.source:source-next-char src) #\a)
    (check-equal (han.source:source-peek-char src) #\b)
    (multiple-value-bind (index line column)
        (han.source:source-location src)
      (check-equal index 1)
      (check-equal line 1)
      (check-equal column 2))))

(deftest test-source-newline-location ()
  (let ((src (han.source:make-char-source (format nil "a~%b"))))
    (check-equal (han.source:source-next-char src) #\a)
    (multiple-value-bind (index line column)
        (han.source:source-location src)
      (check-equal index 1)
      (check-equal line 1)
      (check-equal column 2))
    (check-equal (han.source:source-next-char src) #\Newline)
    (multiple-value-bind (index line column)
        (han.source:source-location src)
      (check-equal index 2)
      (check-equal line 2)
      (check-equal column 1))
    (check-equal (han.source:source-next-char src) #\b)
    (multiple-value-bind (index line column)
        (han.source:source-location src)
      (check-equal index 3)
      (check-equal line 2)
      (check-equal column 2))))

(deftest test-source-peek-string ()
  (let ((src (han.source:make-char-source "abcdef")))
    (check-equal (han.source:source-peek-string src 3) "abc")
    (han.source:source-advance-n src 2)
    (check-equal (han.source:source-peek-string src 3) "cde")
    (han.source:source-advance-n src 10)
    (check-equal (han.source:source-peek-string src 3) "")))

(deftest test-source-mark-and-reset ()
  (let ((src (han.source:make-char-source "abcdef")))
    (han.source:source-advance-n src 2)
    (let ((mark (han.source:make-source-mark src)))
      (han.source:source-advance-n src 3)
      (multiple-value-bind (index line column)
          (han.source:source-location src)
        (check-equal index 5)
        (check-equal line 1)
        (check-equal column 6))
      (han.source:source-reset src mark)
      (multiple-value-bind (index line column)
          (han.source:source-location src)
        (check-equal index 2)
        (check-equal line 1)
        (check-equal column 3))
      (check-equal (han.source:source-peek-char src) #\c))))

(deftest test-source-mark-from-source-p ()
  (let ((src1 (han.source:make-char-source "abc"))
        (src2 (han.source:make-char-source "abc")))
    (let ((mark1 (han.source:make-source-mark src1)))
      (check-equal (han.source:source-mark-from-source-p mark1 src1) t)
      (check-equal (han.source:source-mark-from-source-p mark1 src2) nil)
      (check-equal
       (signal-error-p
        (lambda ()
          (han.source:source-mark-from-source-p mark1 src2 t)))
       t))))

(deftest test-source-span-and-slice ()
  (let ((src (han.source:make-char-source "abcdef")))
    (let ((m1 (han.source:make-source-mark src)))
      (han.source:source-advance-n src 3)
      (let ((m2 (han.source:make-source-mark src)))
        (let ((span (han.source:make-source-span m1 m2)))
          (check-equal (han.source:source-slice src m1 m2) "abc")
          (check-equal (han.source:source-slice-by-span src span) "abc"))))))

(deftest test-source-span-origin-check ()
  (let ((src1 (han.source:make-char-source "abc"))
        (src2 (han.source:make-char-source "xyz")))
    (let ((m1 (han.source:make-source-mark src1))
          (m2 (han.source:make-source-mark src2)))
      (check-equal
       (signal-error-p
        (lambda ()
          (han.source:make-source-span m1 m2)))
       t))))

(deftest test-source-same-origin-p ()
  (let ((src1 (han.source:make-char-source "abc"))
        (src2 (han.source:make-char-source "abc")))
    (let* ((m1 (han.source:make-source-mark src1))
           (m2 (han.source:make-source-mark src1))
           (m3 (han.source:make-source-mark src2))
           (span1 (han.source:make-source-span m1 m2)))
      (check-equal (han.source:source-same-origin-p src1 m1 span1) t)
      (check-equal (han.source:source-same-origin-p src1 m3) nil))))

(deftest test-source-match-char-p ()
  (let ((src (han.source:make-char-source "abc")))
    (check-equal (han.source:source-match-char-p src #\a) t)
    (check-equal (han.source:source-match-char-p src #\b) nil)
    ;; match 不推进
    (multiple-value-bind (index line column)
        (han.source:source-location src)
      (check-equal index 0)
      (check-equal line 1)
      (check-equal column 1))))

(deftest test-source-match-string-p ()
  (let ((src (han.source:make-char-source "abcdef")))
    (check-equal (han.source:source-match-string-p src "abc") t)
    (check-equal (han.source:source-match-string-p src "abd") nil)
    (han.source:source-advance-n src 4)
    (check-equal (han.source:source-match-string-p src "ef") t)
    (check-equal (han.source:source-match-string-p src "efg") nil)))

(deftest test-source-consume-char-if ()
  (let ((src (han.source:make-char-source "abc")))
    (check-equal (han.source:source-consume-char-if src #\a) #\a)
    (multiple-value-bind (index line column)
        (han.source:source-location src)
      (check-equal index 1)
      (check-equal line 1)
      (check-equal column 2))
    ;; 不匹配时不推进
    (check-equal (han.source:source-consume-char-if src #\z) nil)
    (multiple-value-bind (index line column)
        (han.source:source-location src)
      (check-equal index 1)
      (check-equal line 1)
      (check-equal column 2))))

(deftest test-source-consume-string-if ()
  (let ((src (han.source:make-char-source "abcdef")))
    (check-equal (han.source:source-consume-string-if src "abc") "abc")
    (multiple-value-bind (index line column)
        (han.source:source-location src)
      (check-equal index 3)
      (check-equal line 1)
      (check-equal column 4))
    ;; 不匹配时不推进
    (check-equal (han.source:source-consume-string-if src "xyz") nil)
    (multiple-value-bind (index line column)
        (han.source:source-location src)
      (check-equal index 3)
      (check-equal line 1)
      (check-equal column 4))))

(deftest test-source-advance-n ()
  (let ((src (han.source:make-char-source "abc")))
    (han.source:source-advance-n src 2)
    (check-equal (han.source:source-peek-char src) #\c)
    ;; 超过末尾也不该报错
    (han.source:source-advance-n src 10)
    (check-equal (han.source:source-eof-p src) t)))

(deftest test-source-skip-while ()
  (let ((src (han.source:make-char-source "   abc")))
    (han.source:source-skip-while src
                                  (lambda (c)
                                    (char= c #\Space)))
    (check-equal (han.source:source-peek-char src) #\a)
    (multiple-value-bind (index line column)
        (han.source:source-location src)
      (check-equal index 3)
      (check-equal line 1)
      (check-equal column 4))))

(deftest test-source-read-while ()
  (let ((src (han.source:make-char-source "abc123xyz")))
    (check-equal
     (han.source:source-read-while src #'alpha-char-p)
     "abc")
    (multiple-value-bind (index line column)
        (han.source:source-location src)
      (check-equal index 3)
      (check-equal line 1)
      (check-equal column 4))
    (check-equal
     (han.source:source-read-while src #'digit-char-p)
     "123")
    (check-equal
     (han.source:source-read-while src #'alpha-char-p)
     "xyz")
    (check-equal (han.source:source-eof-p src) t)))

(deftest test-source-slice-with-integer ()
  (let ((src (han.source:make-char-source "abcdef")))
    (han.source:source-advance-n src 4)
    (check-equal (han.source:source-slice src 1 4) "bcd")
    (check-equal (han.source:source-slice src 2) "cd")))

(deftest test-source-reset-different-source-error ()
  (let ((src1 (han.source:make-char-source "abc"))
        (src2 (han.source:make-char-source "xyz")))
    (let ((mark1 (han.source:make-source-mark src1)))
      (check-equal
       (signal-error-p
        (lambda ()
          (han.source:source-reset src2 mark1)))
       t))))
